# Vault console (web/server.mjs) configuration.
# Copy to .env and adjust, or pass as --env flags on `dodil ignite app deploy`.

# The app's public (anon) backend FQDN the proxy forwards /api calls to.
BACKEND_URL=https://ask-your-notes-cardinalai.ignite.dodil.cloud/

# Optional: project (public) key injected into read calls that don't carry a key.
# Leave empty while the public tier is open.
PUBLIC_KEY=

# Listen port (Ignite injects PORT; 8789 for local `node server.mjs`).
PORT=8789
